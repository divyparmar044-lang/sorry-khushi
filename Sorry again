<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sorry Khushi 🥺</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
height:100vh;
overflow:hidden;
background:linear-gradient(135deg,#ffd6e7,#ffc0cb);
display:flex;
justify-content:center;
align-items:center;
position:relative;
}

/* Background Sorry Text */
.bg{
position:absolute;
inset:0;
display:grid;
grid-template-columns:repeat(4,1fr);
opacity:0.12;
pointer-events:none;
font-size:28px;
font-weight:bold;
color:#c2185b;
text-align:center;
align-items:center;
}

.card{
width:90%;
max-width:500px;
background:white;
padding:30px;
border-radius:25px;
text-align:center;
box-shadow:0 10px 25px rgba(0,0,0,.15);
z-index:2;
}

h1{
color:#e91e63;
margin-bottom:15px;
}

p{
font-size:18px;
color:#555;
line-height:1.6;
}

button{
border:none;
padding:12px 25px;
margin:10px;
border-radius:20px;
font-size:18px;
cursor:pointer;
}

#yesBtn{
background:#e91e63;
color:white;
}

#noBtn{
background:#ddd;
}

#message{
margin-top:15px;
font-weight:bold;
color:#e91e63;
min-height:30px;
}
</style>
</head>

<body>

<div class="bg">
<div>Sorry 🥺</div>
<div>Sorry 🥺</div>
<div>Sorry 🥺</div>
<div>Sorry 🥺</div>
<div>Sorry 🥺</div>
<div>Sorry 🥺</div>
<div>Sorry 🥺</div>
<div>Sorry 🥺</div>
</div>

<div class="card">

<h1>🥺 Sorry Khushi 🥺</h1>

<p>
Dear <b>Bhatakati Aatma 👻</b><br><br>

Mujhse galti ho gayi... 😔<br>
Kya hum phir se normal ho sakte hain? 🥺
</p>

<br>

<button id="yesBtn">😊 Haan</button>
<button id="noBtn">😒 Nahi</button>

<div id="message"></div>

</div>

<script>

const noBtn = document.getElementById("noBtn");
const yesBtn = document.getElementById("yesBtn");
const message = document.getElementById("message");

const texts = [
"🥺 Ek baar aur soch lo...",
"😔 Abhi bhi gussa ho?",
"😭 Please Khushi...",
"💔 Itna bhi mat satao...",
"🥲 Last try..."
];

let count = 0;

noBtn.addEventListener("mouseover", moveBtn);
noBtn.addEventListener("click", moveBtn);

function moveBtn(){

message.innerHTML = texts[count % texts.length];

noBtn.style.position = "absolute";
noBtn.style.left =
Math.random() * (window.innerWidth - 120) + "px";

noBtn.style.top =
Math.random() * (window.innerHeight - 60) + "px";

count++;
}

yesBtn.addEventListener("click", ()=>{

document.body.innerHTML = `

<div style="
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#ffd6e7,#ffc0cb);
">

<div style="
background:white;
padding:35px;
border-radius:25px;
text-align:center;
max-width:500px;
">

<h1 style="color:#e91e63;">
🎉 Thank You Khushi 🎉
</h1>

<div style="font-size:70px;">
🥳✨🎊
</div>

<p style="
font-size:22px;
margin-top:15px;
color:#555;
">

Bhatakati Aatma 👻 finally maan gayi 😆💖

</p>

<h2 style="color:#e91e63;">
Friendship Saved ✅
</h2>

</div>

</div>

`;

});

</script>

</body>
</html>
